<!DOCTYPE html>
<html lang="en">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Atlas Arena - Home</title>
</head>
<body>
    <header class="topbar">
        <div class="brand">
            <span class="brand-logo">Atlas Arena</span>
        </div>
        <div class="auth-buttons">
            <% if (locals.currentUser) { %>
                <span class="welcome-message">
                    Welcome, <%= locals.currentUser.username %>
                </span>
                <a href="/logout" class="auth-button logout">Sign Out</a>
            <% } else { %>
                <a href="/login" class="auth-button login">Sign In / Join Arena</a>
            <% } %>
        </div>
    </header>

    <main>
        <section class="hero">
            <p>Explore cities around the world and test your knowledge in a map-based trivia experience. 
                <br>
                Click on a location to get started.</p>
        </section>

        <div id="map-placeholder">
          <iframe id="fram"
            src="/interactive-map?cities=<%= cities %>" 
            style="border:1px solid black; width: 100%; height: 100%;"
            title="Interactive World Map">
          </iframe>
            <!-- <p>Interactive Map Component will be loaded here.</p> -->
           
        </div>
        <div class="action-section">
            <button type="button" class="start-quiz-btn" onclick='iframe.contentWindow.postMessage("runRandomPin", "*");'>
                Start Random Quiz
            </button>
        </div>
    </main>

    <section class="leaderboard">
        <h2>Top Players</h2>
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.username || 'Anonymous' %></td>
                            <td><%= user.totalScore || 0 %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="2">No players found yet.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>

    <footer>
        <p>&copy; 2026 Atlas Arena Project</p>
    </footer>

    <script>
        const iframe = document.getElementById("fram");

        

        
    </script>


</body>
</html>





