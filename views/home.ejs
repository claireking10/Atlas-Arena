<!DOCTYPE html>
<html lang="en">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Atlas Arena - Map Trivia</title>
    <style>
body { font-family: sans-serif; text-align: center; }
        
    </style>
</head>
<body>
    <header>
        <h1>Atlas Arena</h1>
        <p>A Map-based Trivia Web application</p>
        
        <div style="margin-top: 15px; margin-bottom: 15px;">
            <% if (currentUser) { %>
                <span style="font-weight: bold; margin-right: 15px;">
                    Welcome to the Arena, <%= currentUser.username %>!
                </span>
                <a href="/logout" style="padding: 8px 16px; background-color: #ff4c4c; color: white; border-radius: 5px; text-decoration: none; font-size: 14px;">Sign Out</a>
            <% } else { %>
                <a href="/login" style="padding: 8px 16px; background-color: #0078D4; color: white; border-radius: 5px; text-decoration: none; font-size: 14px;">Sign In / Join Arena</a>
            <% } %>
        </div>
    </header>

    <main>
        <div id="map-placeholder">
          <p>some text</p>
          <%- include('worldMap') %>
            <!-- <p>Interactive Map Component will be loaded here.</p> -->
        </div>
        <div></div>

        <button type="button" onclick="alert('Start Game functionality coming soon!')">
            Start Random Quiz
        </button>
    </main>

    <section class="leaderboard">
        <h2>Top Players</h2>
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.username || 'Anonymous' %></td>
                            <td><%= user.totalScore || 0 %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="2">No players found yet.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>

    <footer>
        <p>&copy; 2026 Atlas Arena Project</p>
    </footer>
    <script>
        const citiesTable = <%- JSON.stringify(typeof cities !== 'undefined' ? cities : []) %>;
        
        

        function getEntry(idToFind) { 
            
            // Find the specific row in the array
            const entry = citiesTable.find(item => item.name == idToFind);
            
            if (entry) {
                return entry.description;
                //document.getElementById('result').innerText = `Found: ${entry.name}`;
            } else {
                return "City Information not Retrieved";
                //document.getElementById('result').innerText = "Entry not found.";
            }
        }
    </script>
</body>
</html>





