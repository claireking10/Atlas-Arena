<%- include('../partials/header', { page_title: "Home" }) %>
    <main>
        <section class="hero">
            <p>Explore cities around the world and test your knowledge in a map-based trivia experience. 
                <br>
                Click on a location to get started.</p>
        </section>

        <div id="map-placeholder">
            <!-- Interactive Map Component will be loaded here -->

            <iframe id="fram"
                src="/interactive-map?cities=<%= cities %>" 
                style="border:1px solid black; width: 100%; height: 100%;"
                title="Interactive World Map">
            </iframe>
        </div>
        <div class="action-section">
            <button type="button" class="start-quiz-btn" onclick='iframe.contentWindow.postMessage("runRandomPin", "*");'>
                Start Random Quiz
            </button>
        </div>
    </main>

    <section class="leaderboard">
        <h2>Top Players</h2>
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.username || 'Anonymous' %></td>
                            <td><%= user.totalScore || 0 %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="2">No players found yet.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>

    <script>
        // get a reference to the iframe to interact with the map
        const iframe = document.getElementById("fram");
        
    </script>
<%- include('../partials/footer') %>





