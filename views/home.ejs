<!DOCTYPE html>
<html lang="en">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Atlas Arena - Home</title>
    <style>
body { font-family: sans-serif; text-align: center; }
        
    </style>
</head>
<body style="background-color: white;">
    <header>
        <h1>Atlas Arena</h1>
        <p>A Map-based Trivia Web application</p>
    </header>

    <main>
        <div id="map-placeholder">
          <iframe 
            src="/interactive-map?cities=<%= cities %>" 
            style="border:1px solid black; width: 75vw; height: 40vw;">
          </iframe>
            <!-- <p>Interactive Map Component will be loaded here.</p> -->
        </div>
        <div></div>

        <button type="button" onclick="alert('Start Game functionality coming soon!')">
            Start Random Quiz
        </button>
    </main>

    <section class="leaderboard">
        <h2>Top Players</h2>
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.username || 'Anonymous' %></td>
                            <td><%= user.totalScore || 0 %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="2">No players found yet.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>

    <footer>
        <p>&copy; 2026 Atlas Arena Project</p>
    </footer>
